@model LogisticsManagementSystem.Models.ServiceRequest

@{
    ViewData["Title"] = "Delete Service Request";
}

<div class="service-request-delete">
    <div class="text-center mb-5">
        <h1>Delete Service Request</h1>
        <p class="lead text-muted">Are you sure you want to delete this service request? This action cannot be undone.</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            <div class="card shadow">
                <div class="card-header bg-white py-4">
                    <h4 class="mb-0 text-danger">Service Request Information</h4>
                </div>
                <div class="card-body p-5">
                    <dl class="row">
                        <dt class="col-sm-3 fw-semibold text-muted">Contract</dt>
                        <dd class="col-sm-9">@Model?.Contract?.ServiceLevel</dd>

                        <dt class="col-sm-3 fw-semibold text-muted">Description</dt>
                        <dd class="col-sm-9">@Model?.Description</dd>

                        <dt class="col-sm-3 fw-semibold text-muted">Cost</dt>
                        <dd class="col-sm-9">@Model?.Cost</dd>

                        <dt class="col-sm-3 fw-semibold text-muted">Status</dt>
                        <dd class="col-sm-9">@Model?.Status</dd>
                    </dl>

                    <hr class="my-4" />

                    <form asp-action="Delete" class="text-center">
                        <input type="hidden" asp-for="ServiceID" />

                        <div class="d-flex justify-content-center gap-3">
                            <a asp-action="Index" class="btn btn-success btn-lg px-5">Cancel</a>
                            <input type="submit" value="Yes, Delete Request" class="btn btn-danger btn-lg px-5" />
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>