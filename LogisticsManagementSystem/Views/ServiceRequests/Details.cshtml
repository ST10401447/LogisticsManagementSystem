@model LogisticsManagementSystem.Models.ServiceRequest

@{
    ViewData["Title"] = "Service Request Details";
}

<div class="service-request-details">
    <div class="text-center mb-5">
        <h1>Service Request Details</h1>
        <p class="lead text-muted">Complete information about this service request.</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            <div class="card shadow">
                <div class="card-header bg-white py-4">
                    <h4 class="mb-0">Service Request Information</h4>
                </div>
                <div class="card-body p-5">
                    <dl class="row">
                        <dt class="col-sm-3 fw-semibold text-muted">Contract</dt>
                        <dd class="col-sm-9">@Model?.Contract?.ServiceLevel</dd>

                        <dt class="col-sm-3 fw-semibold text-muted">Description</dt>
                        <dd class="col-sm-9">@Model?.Description</dd>

                        <dt class="col-sm-3 fw-semibold text-muted">Cost</dt>
                        <dd class="col-sm-9">@Model?.Cost</dd>

                        <dt class="col-sm-3 fw-semibold text-muted">Status</dt>
                        <dd class="col-sm-9">@Model?.Status</dd>
                    </dl>

                    <hr />

                    <div class="d-flex gap-3">
                        <a asp-action="Edit" asp-route-id="@Model?.ServiceID" class="btn btn-primary btn-lg px-5">Edit</a>
                        <a asp-action="Index" class="btn btn-success btn-lg px-5">Back to List</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>