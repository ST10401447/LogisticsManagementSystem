@model LogisticsManagementSystem.Models.ServiceRequest

@{
    ViewData["Title"] = "Create Service Request";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-success text-white py-3">
                    <h3 class="mb-0 text-center">Create New Service Request</h3>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="ContractID" class="form-label fw-bold">Contract</label>
                            <select asp-for="ContractID" class="form-select form-select-lg" asp-items="ViewBag.ContractID">
                                <option value="">-- Select Contract --</option>
                            </select>
                            <span asp-validation-for="ContractID" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-bold">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Cost" class="form-label fw-bold">Cost (USD)</label>
                            <input asp-for="Cost" class="form-control" placeholder="Enter amount in USD" />
                            <small class="text-muted">ZAR will be calculated automatically</small>
                            <span asp-validation-for="Cost" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Status" class="form-label fw-bold">Status</label>
                            <select asp-for="Status" class="form-select">
                                <option value="Select Status">Select Status</option>
                                <option value="Pending">Pending</option>
                                <option value="Active">Active</option>
                                <option value="Approved">Approved</option>
                                <option value="Rejected">Rejected</option>
                            </select>
                        </div>

                        <div class="d-flex justify-content-end gap-3 pt-3 border-top">
                            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                            <button type="submit" class="btn btn-success">Create Service Request</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>