@model LogisticsManagementSystem.Models.ServiceRequest

@{
    ViewData["Title"] = "Edit Service Request";
}

<div class="service-request-edit">
    <div class="text-center mb-5">
        <h1 class="mb-3">Edit Service Request</h1>
        <p class="lead text-muted">Update the details of this service request below.</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10 col-12">
            <div class="card shadow">
                <div class="card-header bg-white py-4">
                    <h4 class="mb-0">Service Request Information</h4>
                </div>
                <div class="card-body p-5">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>
                        <input type="hidden" asp-for="ServiceID" />

                        <div class="row g-4">
                            <div class="col-md-12">
                                <label asp-for="ContractID" class="control-label fw-semibold"></label>
                                <select asp-for="ContractID" class="form-control form-control-lg" asp-items="ViewBag.ContractID"></select>
                                <span asp-validation-for="ContractID" class="text-danger"></span>
                            </div>

                            <div class="col-md-12">
                                <label asp-for="Description" class="control-label fw-semibold"></label>
                                <textarea asp-for="Description" class="form-control form-control-lg" rows="4"></textarea>
                                <span asp-validation-for="Description" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Cost" class="control-label fw-semibold"></label>
                                <input asp-for="Cost" class="form-control form-control-lg" type="number" step="0.01" />
                                <span asp-validation-for="Cost" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Status" class="control-label fw-semibold"></label>
                                <input asp-for="Status" class="form-control form-control-lg" />
                                <span asp-validation-for="Status" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-3 mt-5">
                            <a asp-action="Index" class="btn btn-light btn-lg px-5">Cancel</a>
                            <input type="submit" value="Save Changes" class="btn btn-primary btn-lg px-5" />
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>