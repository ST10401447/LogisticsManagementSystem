@model LogisticsManagementSystem.Models.Contract
@{
    ViewData["Title"] = "Delete";
}

<div class="contract-delete">

    <div class="delete-header">
        <h1>Delete Contract</h1>
        <h3 class="text-danger">Are you sure you want to delete this contract?</h3>
        <p class="text-muted">This action cannot be undone.</p>
    </div>

    <div class="details-card">
        <h4>Contract Information</h4>
        <hr />

        <dl class="row">
            <dt class="col-sm-3">Client</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Client.ContactNo)</dd>

            <dt class="col-sm-3">Start Date</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.StartDate)</dd>

            <dt class="col-sm-3">End Date</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.EndDate)</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Status)</dd>

            <dt class="col-sm-3">Service Level</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.ServiceLevel)</dd>

            <dt class="col-sm-3">Signed Agreement</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.SignedAgreement)</dd>
        </dl>
    </div>

    <div class="delete-actions">
        <form asp-action="Delete" style="display: inline;">
            <input type="hidden" asp-for="ContractID" />
            <input type="submit" value="Yes, Delete Contract" class="btn btn-danger btn-lg" />
        </form>
        <a asp-action="Index" class="btn btn-secondary btn-lg">Cancel</a>
    </div>

</div>