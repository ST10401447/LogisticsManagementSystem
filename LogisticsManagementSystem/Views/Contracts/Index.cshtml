@model IEnumerable<LogisticsManagementSystem.Models.Contract>

@{
    ViewData["Title"] = "Contracts";
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary"><i class="bi bi-file-text-fill"></i> Contracts Management</h2>
        <a asp-action="Create" class="btn btn-success btn-lg shadow-sm">
            <i class="bi bi-plus-circle me-2"></i> Create New Contract
        </a>
    </div>

    <!-- Filter Section -->
    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <form asp-action="Index" method="get" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">Status</label>
                    <select name="status" class="form-select form-select-lg" style="height: 58px;">
                        <option value="">----------- Select Status ----------</option>
                        <option value="Draft" selected="@(ViewBag.CurrentStatus == "Draft")">Draft</option>
                        <option value="Active" selected="@(ViewBag.CurrentStatus == "Active")">Active</option>
                        <option value="OnHold" selected="@(ViewBag.CurrentStatus == "OnHold")">On Hold</option>
                        <option value="Expired" selected="@(ViewBag.CurrentStatus == "Expired")">Expired</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Start Date From</label>
                    <input type="date" name="startDate" class="form-control" value="@ViewBag.CurrentStartDate" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">End Date To</label>
                    <input type="date" name="endDate" class="form-control" value="@ViewBag.CurrentEndDate" />
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary flex-fill">Search</button>
                    <a asp-action="Index" class="btn btn-secondary flex-fill">Clear</a>
                </div>
            </form>
        </div>
    </div>

    <!-- Contracts Table -->
    <div class="card shadow">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Client</th>
                            <th>Start Date</th>
                            <th>End Date</th>
                            <th>Status</th>
                            <th>Service Level</th>
                            <th>Signed Agreement</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><strong>@item.Client?.Name</strong></td>
                                <td>@item.StartDate.ToString("yyyy-MM-dd")</td>
                                <td>@item.EndDate.ToString("yyyy-MM-dd")</td>
                                <td>
                                    <span class="badge fs-6 px-3 py-2
                                            @(item.Status == "Active" ? "bg-success" :item.Status == "Expired" ? "bg-danger" :item.Status == "OnHold" ? "bg-warning" : "bg-info")">
                                    @item.Status
                                </span>
                            </td>
                            <td>@item.ServiceLevel</td>
                            <td style="max-width: 280px;">
                                @if (!string.IsNullOrEmpty(item.SignedAgreement))
                                    {
                                        <div>
                                            <!-- Clickable File Link -->
                                            <a asp-action="Download" asp-route-id="@item.ContractID"
                                               class="text-primary text-truncate d-block mb-2 small"
                                               title="@item.SignedAgreement">
                                                @item.SignedAgreement
                                            </a>

                                            <!-- Download Button -->
                                            <a asp-action="Download" asp-route-id="@item.ContractID"
                                               class="btn btn-warning btn-sm">
                                                <i class="bi bi-download"></i> Download PDF
                                            </a>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">No file</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Edit" asp-route-id="@item.ContractID"
                                           class="btn btn-primary btn-sm">Edit</a>
                                        <a asp-action="Details" asp-route-id="@item.ContractID"
                                           class="btn btn-info btn-sm">Details</a>
                                        <a asp-action="Delete" asp-route-id="@item.ContractID"
                                           class="btn btn-danger btn-sm">Delete</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>