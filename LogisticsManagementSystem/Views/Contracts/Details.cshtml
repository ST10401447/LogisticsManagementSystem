@model LogisticsManagementSystem.Models.Contract
@{
    ViewData["Title"] = "Details";
}

<div class="contract-details">

    <div class="details-header">
        <h1>Contract Details</h1>
        <p class="text-muted">View complete contract information</p>
    </div>

    <div class="details-card">
        <h4>Contract Information</h4>
        <hr />

        <dl class="row">
            <dt class="col-sm-3">Client</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Client.ContactNo)</dd>

            <dt class="col-sm-3">Start Date</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.StartDate)</dd>

            <dt class="col-sm-3">End Date</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.EndDate)</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Status)</dd>

            <dt class="col-sm-3">Service Level</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.ServiceLevel)</dd>

            <dt class="col-sm-3">Signed Agreement</dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.SignedAgreement)
                @if (!string.IsNullOrEmpty(Model?.SignedAgreement))
                {
                    <br />
                
                    <br />
                    <a asp-action="Download" asp-route-id="@Model.ContractID" class="btn btn-success">
                        <i class="fas fa-download"></i> Download Signed Agreement PDF
                    </a>
                }
            </dd>
        </dl>
    </div>

    <div class="details-actions">
        <a asp-action="Edit" asp-route-id="@Model?.ContractID" class="btn btn-primary">Edit Contract</a>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>

</div>