@model IEnumerable<LogisticsManagementSystem.Models.Client>

@{
    ViewData["Title"] = "Clients";
}

<div class="clients-index">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Clients</h1>
        <a asp-action="Create" class="btn btn-success btn-create">
            Create New Client
        </a>
    </div>

    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>CLIENTID</th>
                <th>NAME</th>
                <th>CONTACTNO</th>
                <th>EMAIL</th>
                <th>REGION</th>
                <th>ACTIONS</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><strong>@item.ClientID</strong></td>
                    <td>@item.Name</td>
                    <td>@item.ContactNo</td>
                    <td>@item.Email</td>
                    <td>@item.Region</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.ClientID" class="btn btn-sm btn-primary btn-action me-2">Edit</a>
                        <a asp-action="Details" asp-route-id="@item.ClientID" class="btn btn-sm btn-warning btn-action me-2">Details</a>
                        <a asp-action="Delete" asp-route-id="@item.ClientID" class="btn btn-sm btn-danger btn-action">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>