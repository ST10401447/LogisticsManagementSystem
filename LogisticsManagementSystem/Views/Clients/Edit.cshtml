@model LogisticsManagementSystem.Models.Client

@{
    ViewData["Title"] = "Edit Client";
}

<div class="clients-edit">
    <div class="text-center mb-5">
        <h1 class="mb-2">Edit Client</h1>
        <p class="lead text-muted">Update the client's information below. All fields are required.</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10 col-12">
            <div class="card shadow">
                <div class="card-header bg-white py-4">
                    <h4 class="mb-0">Client Information</h4>
                </div>
                <div class="card-body p-5">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>
                        <input type="hidden" asp-for="ClientID" />

                        <div class="row g-4">
                            <div class="col-md-12">
                                <label asp-for="Name" class="control-label fw-semibold"></label>
                                <input asp-for="Name" class="form-control form-control-lg" />
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="ContactNo" class="control-label fw-semibold"></label>
                                <input asp-for="ContactNo" class="form-control form-control-lg" />
                                <span asp-validation-for="ContactNo" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Region" class="control-label fw-semibold"></label>
                                <input asp-for="Region" class="form-control form-control-lg" />
                                <span asp-validation-for="Region" class="text-danger"></span>
                            </div>

                            <div class="col-md-12">
                                <label asp-for="Email" class="control-label fw-semibold"></label>
                                <input asp-for="Email" class="form-control form-control-lg" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-3 mt-5">
                            <a asp-action="Index" class="btn btn-light btn-lg px-5">Cancel</a>
                            <input type="submit" value="Save Changes" class="btn btn-primary btn-lg px-5" />
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>