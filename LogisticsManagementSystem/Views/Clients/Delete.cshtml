@model LogisticsManagementSystem.Models.Client

@{
    ViewData["Title"] = "Delete Client";
}

<div class="clients-delete">
    <div class="text-center mb-5">
        <h1 class="mb-3">Delete Client</h1>
        <p class="lead text-muted">Are you sure you want to delete this client? This action cannot be undone.</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10 col-12">
            <div class="card shadow">
                <div class="card-header bg-white py-4">
                    <h4 class="mb-0 text-danger">Client Information</h4>
                </div>
                <div class="card-body p-5">
                    <dl class="row">
                        <dt class="col-sm-3 fw-semibold text-muted">Name</dt>
                        <dd class="col-sm-9">@Model?.Name</dd>

                        <dt class="col-sm-3 fw-semibold text-muted">Contact No</dt>
                        <dd class="col-sm-9">@Model?.ContactNo</dd>

                        <dt class="col-sm-3 fw-semibold text-muted">Email</dt>
                        <dd class="col-sm-9">@Model?.Email</dd>

                        <dt class="col-sm-3 fw-semibold text-muted">Region</dt>
                        <dd class="col-sm-9">@Model?.Region</dd>
                    </dl>

                    <hr class="my-4" />

                    <form asp-action="Delete" class="d-flex justify-content-center gap-3 flex-wrap">
                        <input type="hidden" asp-for="ClientID" />

                        <a asp-action="Index" class="btn btn-success btn-lg px-5">
                            <i class="bi bi-arrow-left me-2"></i>Cancel
                        </a>

                        <button type="submit" class="btn btn-danger btn-lg px-5">
                            Yes, Delete Client
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>