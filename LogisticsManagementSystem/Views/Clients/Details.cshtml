@model LogisticsManagementSystem.Models.Client

@{
    ViewData["Title"] = "Client Details";
}

<div class="clients-details">
    <div class="text-center mb-5">
        <h1 class="mb-3">Client Details</h1>
        <p class="lead text-muted">View complete information for this client.</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10 col-12">
            <div class="card shadow">
                <div class="card-header bg-white py-4">
                    <h4 class="mb-0">Client Information</h4>
                </div>
                <div class="card-body p-5">
                    <dl class="row">
                        <dt class="col-sm-3 fw-semibold text-muted">Name</dt>
                        <dd class="col-sm-9">@Model?.Name</dd>

                        <dt class="col-sm-3 fw-semibold text-muted">Contact No</dt>
                        <dd class="col-sm-9">@Model?.ContactNo</dd>

                        <dt class="col-sm-3 fw-semibold text-muted">Email</dt>
                        <dd class="col-sm-9">@Model?.Email</dd>

                        <dt class="col-sm-3 fw-semibold text-muted">Region</dt>
                        <dd class="col-sm-9">@Model?.Region</dd>
                    </dl>

                    <hr class="my-4" />

                    <div class="d-flex flex-wrap gap-3">
                        <a asp-action="Edit" asp-route-id="@Model?.ClientID" class="btn btn-primary btn-lg px-5">
                            Edit Client
                        </a>
                        <a asp-action="Index" class="btn btn-success btn-lg px-5">
                            <i class="bi bi-arrow-left me-2"></i>Back to Clients
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>